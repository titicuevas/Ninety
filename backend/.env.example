PORT=3001
NODE_ENV=development
CLIENT_URL=http://localhost:5173

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# SOLO backend — NUNCA en frontend ni en GitHub
SUPABASE_SECRET_KEY=your-secret-key
SUPABASE_JWKS_URL=https://your-project.supabase.co/auth/v1/.well-known/jwks.json

# Para migraciones automáticas (Settings → Database → Connection string URI)
# SUPABASE_DB_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# o solo la contraseña de la base de datos:
# SUPABASE_DB_PASSWORD=your-database-password

FOOTBALL_DATA_API_KEY=your-football-data-api-key

# Usuario de prueba (solo local — npm run seed:test-user)
# TEST_USER_EMAIL=demo@ninety.app
# TEST_USER_PASSWORD=your-test-password
